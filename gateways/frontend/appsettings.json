{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "sewersRoute": {
        "ClusterId": "sewersCluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api"
          }
        ]
      },
      "portalRoute": {
        "ClusterId": "portalCluster",
        "Match": {
          "Path": "/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "sewersCluster": {
        "Destinations": {
          "sewersDestination": {
            "Address": "http://localhost:13000/"
          }
        }
      },
      "portalCluster": {
        "Destinations": {
          "portalDestination": {
            "Address": "http://localhost:13001/"
          }
        }
      }
    }
  }
}