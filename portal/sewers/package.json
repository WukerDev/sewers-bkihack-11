{
  "name": "sewers",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "mcp": "ruler apply",
    "mcp:revert": "ruler revert",
"generate": "protoc --plugin=protoc-gen-ts_proto=.\\node_modules\\.bin\\protoc-gen-ts_proto.cmd --ts_proto_out=./src/proto -I ../../protos ../../protos/main.proto --ts_proto_opt=esModuleInterop=true" },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@mdi/font": "7.4.47",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.4",
    "ts-proto": "^2.11.6",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.6.4",
    "vuetify": "^4.0.2"
  },
  "devDependencies": {
    "@intellectronica/ruler": "^0.3.37",
    "@tsconfig/node22": "^22.0.5",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.4",
    "eslint-config-vuetify": "^4.3.4",
    "npm-run-all2": "^8.0.4",
    "sass-embedded": "^1.98.0",
    "typescript": "~5.9.3",
    "unplugin-fonts": "^1.4.0",
    "unplugin-vue-router": "^0.19.2",
    "vite": "^8.0.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "unplugin-fonts": {
      "vite": "^8.0.0"
    }
  }
}
